{
  "name": "scribe-workspace",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*",
    "tests/integration/*"
  ],
  "scripts": {
    "build": "tsdown --workspace",
    "test": "vitest run",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "typecheck": "node ./node_modules/@typescript/native/bin/tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@scribe/mdx": "workspace:*",
    "@typescript/native": "npm:typescript@7.0.2",
    "@types/react": "19.2.17",
    "@types/node": "22.20.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsdown": "0.22.7",
    "typescript": "6.0.2",
    "vitest": "4.1.10"
  }
}
