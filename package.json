{
  "name": "scribe-workspace",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*",
    "tests/integration/*"
  ],
  "overrides": {
    "@types/mdx": "2.0.14",
    "postcss": "8.5.19"
  },
  "scripts": {
    "build": "tsdown --workspace",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "docs:check": "node scripts/sync-package-docs.mjs --check",
    "docs:sync": "node scripts/sync-package-docs.mjs",
    "release:inspect": "node scripts/inspect-tarballs.mjs .scribe-release",
    "release:bundle-scan": "node scripts/scan-browser-bundles.mjs",
    "release:check": "node scripts/check-release-alignment.mjs",
    "release:consumers": "node scripts/test-packed-consumers.mjs",
    "release:pack": "node scripts/pack-packages.mjs",
    "release:pack:dry": "node scripts/pack-packages.mjs --dry-run",
    "release:packages": "changeset publish --no-git-tag",
    "release:visual": "node scripts/run-helium-visual.mjs --require-helium",
    "portability:check": "node scripts/check-portability.mjs",
    "test": "vitest run",
    "test:browser": "playwright test --config playwright.config.ts",
    "test:browser:chromium": "playwright test --config playwright.config.ts --project=chromium",
    "test:browser:firefox": "playwright test --config playwright.config.ts --project=firefox",
    "test:browser:webkit": "playwright test --config playwright.config.ts --project=webkit",
    "test:portability": "node scripts/test-portable-cli.mjs",
    "test:studio:browser": "playwright test --config playwright.studio.config.ts",
    "test:release": "node scripts/check-release-alignment.mjs && vitest run tests/release",
    "test:visual": "node scripts/run-helium-visual.mjs",
    "test:visual:helium": "node scripts/run-helium-visual.mjs",
    "test:visual:update": "node scripts/run-helium-visual.mjs --update-snapshots",
    "typecheck": "node ./node_modules/@typescript/native/bin/tsc --noEmit -p tsconfig.json",
    "version:packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "@playwright/test": "1.61.1",
    "@scribe-sdk/mdx": "workspace:*",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@typescript/native": "npm:typescript@7.0.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsdown": "0.22.7",
    "typescript": "6.0.2",
    "vitest": "4.1.10"
  }
}
