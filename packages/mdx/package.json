{
  "name": "@scribe-sdk/mdx",
  "version": "0.1.0-alpha.4",
  "description": "Compile-time MDX pipeline for Scribe tables, diagnostics, anchors, and Shiki output.",
  "author": "aetosdios27",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./next": {
      "types": "./dist/next.d.mts",
      "import": "./dist/next.mjs",
      "default": "./dist/next.mjs"
    },
    "./next-remote": {
      "types": "./dist/next-remote.d.mts",
      "import": "./dist/next-remote.mjs",
      "default": "./dist/next-remote.mjs"
    },
    "./remark": {
      "types": "./dist/remark.d.mts",
      "import": "./dist/remark.mjs",
      "default": "./dist/remark.mjs"
    },
    "./rehype": {
      "types": "./dist/rehype.d.mts",
      "import": "./dist/rehype.mjs",
      "default": "./dist/rehype.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "node ../../scripts/sync-package-docs.mjs --check"
  },
  "sideEffects": false,
  "dependencies": {
    "@mdx-js/mdx": "3.1.1",
    "hast-util-to-string": "3.0.1",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "shiki": "4.3.1",
    "unified": "11.0.5",
    "unist-util-visit": "5.0.0",
    "vfile": "6.0.3"
  },
  "devDependencies": {
    "@types/hast": "3.0.4",
    "@types/react": "19.2.17"
  },
  "keywords": [
    "scribe",
    "mdx",
    "shiki",
    "publishing",
    "technical-writing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aetosdios27/scribe.git",
    "directory": "packages/mdx"
  },
  "homepage": "https://github.com/aetosdios27/scribe#readme",
  "bugs": {
    "url": "https://github.com/aetosdios27/scribe/issues"
  }
}
